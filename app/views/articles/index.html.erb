<div class="flex justify-between items-center mb-8">
  <h2 class="text-2xl font-bold">Архив статей</h2>
  <%= link_to "Сгенерировать новую", new_article_path, class: "bg-stone-900 text-white px-4 py-2 rounded font-sans text-sm hover:bg-stone-700" %>
</div>

<% if @articles.empty? %>
  <div class="text-center py-16 text-stone-400">
    <p class="text-lg mb-2">Пока нет ни одной статьи</p>
    <p class="text-sm">Нажмите «Сгенерировать новую» чтобы создать первую</p>
  </div>
<% else %>
  <div class="space-y-6">
    <% @articles.each do |article| %>
      <%= link_to article_path(article), class: "block border border-stone-200 bg-white p-6 hover:shadow-md transition-shadow rounded" do %>
        <div class="flex items-center gap-3 mb-2 font-sans text-xs text-stone-500">
          <span class="bg-stone-100 px-2 py-0.5 rounded uppercase tracking-wider"><%= article.rubric %></span>
          <span><%= article.created_at.strftime("%d.%m.%Y %H:%M") %></span>
          <span class="<%= article.status == 'completed' ? 'text-green-600' : 'text-amber-600' %>">
            <%= article.status %>
          </span>
        </div>
        <h3 class="text-xl font-bold mb-2"><%= article.topic %></h3>
        <% if article.content.present? %>
          <p class="text-stone-600 text-sm line-clamp-3"><%= truncate(article.content, length: 200) %></p>
        <% end %>
        <div class="mt-3 font-sans text-xs text-stone-400">
          Модель: <%= article.model %> • T=<%= article.temperature %> • max_tokens=<%= article.max_tokens %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
