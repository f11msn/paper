<div class="mb-6 flex items-center justify-between">
  <%= link_to "← Назад к архиву", articles_path, class: "font-sans text-sm text-stone-500 hover:text-stone-700" %>
  <div class="flex gap-4">
    <% if @article.content.present? %>
      <%= link_to "📄 PDF", pdf_article_path(@article), target: "_blank", class: "bg-white border border-stone-300 text-stone-700 px-4 py-2 rounded font-sans text-sm hover:bg-stone-50" %>
    <% end %>
    <%= button_to "↻ Сгенерировать заново", retry_article_path(@article), method: :post, class: "bg-stone-900 text-white px-4 py-2 rounded font-sans text-sm hover:bg-stone-700 cursor-pointer", data: { turbo_confirm: "Перегенерировать статью? Текущий текст будет заменён." } %>
  </div>
</div>

<div class="grid grid-cols-3 gap-8">
  <%# Article column %>
  <div class="col-span-2">
    <div class="bg-white border border-stone-200 rounded p-8">
      <div class="flex items-center gap-3 mb-4 font-sans text-xs text-stone-500">
        <span class="bg-stone-100 px-2 py-0.5 rounded uppercase tracking-wider"><%= @article.rubric %></span>
        <span><%= @article.created_at.strftime("%d.%m.%Y %H:%M") %></span>
      </div>

      <h2 class="text-2xl font-bold mb-6"><%= @article.topic %></h2>

      <% if @article.content.present? %>
        <div class="prose max-w-none leading-relaxed">
          <%= render_markdown(@article.content) %>
        </div>
      <% else %>
        <p class="text-stone-400 italic">Статья не была сгенерирована</p>
      <% end %>
    </div>
  </div>

  <%# Debug Panel %>
  <div class="col-span-1 space-y-4">
    <h3 class="font-sans text-sm font-bold uppercase tracking-wider text-stone-500">Debug Panel</h3>

    <%# Parameters %>
    <div class="bg-stone-800 text-stone-100 rounded p-4 text-xs font-mono">
      <p class="text-stone-400 mb-2 font-sans uppercase tracking-wider text-[10px]">Параметры</p>
      <p><span class="text-emerald-400">model:</span> <%= @article.model %></p>
      <p><span class="text-emerald-400">temperature:</span> <%= @article.temperature %></p>
      <p><span class="text-emerald-400">max_tokens:</span> <%= @article.max_tokens %></p>
      <p><span class="text-emerald-400">status:</span> <%= @article.status %></p>
    </div>

    <%# System Prompt %>
    <div class="bg-stone-800 text-stone-100 rounded p-4 text-xs font-mono">
      <p class="text-stone-400 mb-2 font-sans uppercase tracking-wider text-[10px]">
        System Message
        <span class="text-amber-400">(role: "system")</span>
      </p>
      <pre class="whitespace-pre-wrap text-stone-300"><%= @article.system_prompt %></pre>
    </div>

    <%# Tool Calls Log %>
    <% if @article.tool_calls_log.present? && @article.tool_calls_log.any? %>
      <div class="bg-stone-800 text-stone-100 rounded p-4 text-xs font-mono">
        <p class="text-stone-400 mb-2 font-sans uppercase tracking-wider text-[10px]">
          Tool Calls
          <span class="text-amber-400">(function calling)</span>
        </p>
        <% @article.tool_calls_log.each_with_index do |tc, i| %>
          <div class="<%= 'mt-3 pt-3 border-t border-stone-600' if i > 0 %>">
            <p><span class="text-cyan-400">function:</span> <%= tc["function_name"] || tc[:function_name] %></p>
            <p><span class="text-cyan-400">arguments:</span> <%= (tc["arguments"] || tc[:arguments]).to_json %></p>
            <p class="mt-1"><span class="text-green-400">result:</span></p>
            <pre class="whitespace-pre-wrap text-stone-400 ml-2"><%= JSON.pretty_generate(JSON.parse(tc["result"] || tc[:result])) rescue tc["result"] || tc[:result] %></pre>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Full API Log %>
    <% if @article.api_log.present? %>
      <details class="bg-stone-800 text-stone-100 rounded text-xs font-mono">
        <summary class="p-4 cursor-pointer text-stone-400 font-sans uppercase tracking-wider text-[10px] hover:text-stone-200">
          Полный API лог (<%= @article.api_log.length %> запросов)
        </summary>
        <div class="px-4 pb-4">
          <pre class="whitespace-pre-wrap text-stone-300 max-h-96 overflow-y-auto"><%= JSON.pretty_generate(@article.api_log) %></pre>
        </div>
      </details>
    <% end %>
  </div>
</div>
