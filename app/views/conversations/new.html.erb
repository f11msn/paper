<h2 class="text-2xl font-bold mb-6">Новый чат</h2>

<%= form_with(model: @conversation, class: "space-y-6 max-w-2xl") do |f| %>
  <% if @conversation.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-4 rounded font-sans text-sm">
      <% @conversation.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="block font-sans text-sm font-medium mb-1">Название чата</label>
    <%= f.text_field :title, class: "w-full border border-stone-300 rounded px-3 py-2 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-stone-400", placeholder: "Обсуждение статьи о нефти" %>
  </div>

  <div>
    <label class="block font-sans text-sm font-medium mb-1">
      System Message
      <span class="text-stone-400 font-normal">— задаёт роль AI-редактора</span>
    </label>
    <%= f.text_area :system_prompt, rows: 6, class: "w-full border border-stone-300 rounded px-3 py-2 font-sans text-sm font-mono focus:outline-none focus:ring-2 focus:ring-stone-400" %>
    <p class="text-xs text-stone-400 mt-1 font-sans">
      💡 System message сохраняется как первое сообщение в conversation. Все последующие user/assistant сообщения добавляются в массив messages и отправляются модели целиком — так работает контекст диалога.
    </p>
  </div>

  <div>
    <%= f.submit "Создать чат", class: "bg-stone-900 text-white px-6 py-3 rounded font-sans text-sm hover:bg-stone-700 cursor-pointer" %>
  </div>
<% end %>
